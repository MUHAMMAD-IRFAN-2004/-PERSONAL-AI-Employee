# Environment Variables Template
# Copy this file to .env and fill in your actual credentials
# NEVER commit .env to version control!

# ================================
# Development Settings
# ================================
DRY_RUN=false  # Set to 'false' for production

# ================================
# Gmail API Credentials
# ================================
# Get these from: https://console.cloud.google.com/
GMAIL_CLIENT_ID=your_gmail_client_id_here
GMAIL_CLIENT_SECRET=your_gmail_client_secret_here
GMAIL_REFRESH_TOKEN=your_refresh_token_here

# ================================
# WhatsApp Settings (Silver Tier)
# ================================
# Path to store WhatsApp Web session
WHATSAPP_SESSION_PATH=./whatsapp_session
# Keywords to monitor (comma-separated)
WHATSAPP_KEYWORDS=urgent,asap,invoice,payment,help
# Priority senders (comma-separated names or numbers)
WHATSAPP_PRIORITY_SENDERS=Boss Name,Important Client
# Run headless (true/false)
WHATSAPP_HEADLESS=false
# Check interval in seconds
WHATSAPP_CHECK_INTERVAL=30

# ================================
# Banking API (Optional)
# ================================
BANK_API_TOKEN=your_bank_api_token_here
BANK_API_URL=https://api.yourbank.com/v1

# ================================
# Social Media (Silver Tier)
# ================================
# LinkedIn - Use email/password for Playwright automation
LINKEDIN_EMAIL=your.email@example.com
LINKEDIN_PASSWORD=your_password_here
LINKEDIN_DAILY_LIMIT=5

# Twitter/X - Use username/password for Playwright automation
TWITTER_USERNAME=your_username_here
TWITTER_PASSWORD=your_password_here
TWITTER_DAILY_LIMIT=10

# Social Media Poster Settings
SOCIAL_HEADLESS=false
SOCIAL_CHECK_INTERVAL=300
POST_DELAY=60

# Facebook (Future)
FACEBOOK_ACCESS_TOKEN=your_facebook_token_here
FACEBOOK_PAGE_ID=your_page_id_here

# Instagram (Future)
INSTAGRAM_ACCESS_TOKEN=your_instagram_token_here

# ================================
# MCP Server Settings
# ================================
MCP_PLAYWRIGHT_PORT=8808
MCP_PLAYWRIGHT_SHARED_CONTEXT=true

# ================================
# Notification Settings (Optional)
# ================================
SLACK_WEBHOOK_URL=your_slack_webhook_url_here
DISCORD_WEBHOOK_URL=your_discord_webhook_url_here

# ================================
# Obsidian Vault Path
# ================================
VAULT_PATH=D:\PIAIC AI\-PERSONAL-AI-Employee\AI_Employee_Vault

# ================================
# Rate Limiting
# ================================
MAX_EMAILS_PER_HOUR=10
MAX_PAYMENTS_PER_HOUR=3
MAX_SOCIAL_POSTS_PER_DAY=10

# ================================
# Approval System (Silver Tier)
# ================================
APPROVAL_CHECK_INTERVAL=10
AUTO_APPROVE_LOW_RISK=true
HIGH_RISK_THRESHOLD=50
MEDIUM_RISK_THRESHOLD=20

# Payment-specific thresholds
PAYMENT_AUTO_APPROVE_THRESHOLD=100  # USD
PAYMENT_APPROVAL_REQUIRED_THRESHOLD=500  # USD

# ================================
# Logging
# ================================
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR
LOG_FILE=logs/ai_employee.log

# ================================
# Odoo Integration (Gold Tier+)
# ================================
ODOO_URL=http://localhost:8069
ODOO_DB=your_database_name
ODOO_USERNAME=your_odoo_username
ODOO_API_KEY=your_odoo_api_key

# ================================
# Cloud Deployment (Platinum Tier)
# ================================
CLOUD_AGENT_URL=https://your-cloud-agent.example.com
CLOUD_API_KEY=your_cloud_api_key
SYNC_METHOD=git  # git or syncthing

# ================================
# Security
# ================================
ENCRYPTION_KEY=your_32_byte_encryption_key_here
SESSION_SECRET=your_session_secret_here

# ================================
# Watcher Check Intervals (seconds)
# ================================
GMAIL_CHECK_INTERVAL=120
FILESYSTEM_CHECK_INTERVAL=60

# ================================
# Emergency Contacts
# ================================
EMERGENCY_EMAIL=your_email@example.com
EMERGENCY_PHONE=+1234567890
